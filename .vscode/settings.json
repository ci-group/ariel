{
    "cSpell.customDictionaries": {
        "custom": true,
        "internal-terms": false,
        "project-words": {
            "addWords": true,
            "description": "Words used in this project",
            "name": "project-words",
            "path": "${workspaceRoot}/.vscode/project-words.txt"
        }
    },
    "explorerExclude.backup": {},
    "files.exclude": {
        "**/.git": true,
        "**/.svn": false,
        "**/.hg": false,
        "**/.DS_Store": true,
        "**/Thumbs.db": false,
        "**/.mypy_cache": true,
        "**/.nox": true,
        "**/.pytest_cache": true,
        "**/__pycache__": true,
        ".typings": false,
        ".venv": false,
        "pyproject.toml": true,
        "pyrightconfig.json": true,
        "ruff.toml": true,
        "README.md": true,
        "log.md": true,
        "mypy.ini": true,
        "LICENSE": true,
        "CONTRIBUTING.md": true,
        "CODE_OF_CONDUCT.md": true,
        "3_spider_vision_new.npy": true,
        "_templates": true,
        "resources": true,
        "docs/resources": true,
        "**/resources": true,
        "docs/*.*": true,
        "**/docs": true,
        "docs": true,
        ".gitattributes": true,
        "**/.editorconfig": true,
        ".editorconfig": true,
        "wiki": true,
        ".pre-commit-config.yaml": true,
        ".python-version": true,
        "uv.lock": true,
        ".github": true
    },
    "python-envs.pythonProjects": [],
    "python.testing.pytestArgs": [
        "tests"
    ],
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "ruff.path": [
        "/home/vscode/.local/bin/ruff"
    ],
    "workbench.iconTheme": "material-icon-theme"
}